{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Update git submodules",
            "type": "shell",
            "command": "git",
            "args": ["submodule", "update", "--init", "--recursive"],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "runOptions": {
                "runOn": "folderOpen"
            }
        }
    ]
}

